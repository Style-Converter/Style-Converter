{
  "components": {
    "_comment_MEGA_LAYOUTS": { "properties": { "content": "'=== MEGA NESTED LAYOUTS ===' " } },

    "MegaLayout_DashboardApp": {
      "properties": {
        "display": "grid",
        "grid-template-columns": "[sidebar] 280px [main] 1fr",
        "grid-template-rows": "[header] 64px [content] 1fr [footer] 48px",
        "min-height": "100vh",
        "background": "linear-gradient(135deg, #1a1a2e 0%, #16213e 100%)"
      },
      "children": {
        "Sidebar": {
          "properties": {
            "grid-area": "sidebar",
            "background": "rgba(255,255,255,0.05)",
            "backdrop-filter": "blur(10px)",
            "border-right": "1px solid rgba(255,255,255,0.1)",
            "display": "flex",
            "flex-direction": "column",
            "padding": "24px 16px",
            "gap": "8px"
          },
          "children": {
            "Logo": {
              "properties": {
                "height": "48px",
                "margin-bottom": "24px",
                "display": "flex",
                "align-items": "center",
                "gap": "12px"
              },
              "children": {
                "LogoIcon": {
                  "properties": {
                    "width": "40px",
                    "height": "40px",
                    "background": "linear-gradient(135deg, #667eea 0%, #764ba2 100%)",
                    "border-radius": "12px",
                    "box-shadow": "0 4px 15px rgba(102, 126, 234, 0.4)"
                  }
                },
                "LogoText": {
                  "properties": {
                    "font-size": "20px",
                    "font-weight": "700",
                    "color": "white",
                    "letter-spacing": "-0.5px"
                  }
                }
              }
            },
            "Navigation": {
              "properties": {
                "display": "flex",
                "flex-direction": "column",
                "gap": "4px",
                "flex": "1"
              },
              "children": {
                "NavItemDashboard": {
                  "properties": {
                    "display": "flex",
                    "align-items": "center",
                    "gap": "12px",
                    "padding": "12px 16px",
                    "border-radius": "10px",
                    "background": "rgba(102, 126, 234, 0.2)",
                    "color": "#667eea",
                    "font-weight": "500",
                    "cursor": "pointer",
                    "transition": "all 0.2s ease"
                  }
                },
                "NavItemAnalytics": {
                  "properties": {
                    "display": "flex",
                    "align-items": "center",
                    "gap": "12px",
                    "padding": "12px 16px",
                    "border-radius": "10px",
                    "color": "rgba(255,255,255,0.7)",
                    "cursor": "pointer",
                    "transition": "all 0.2s ease"
                  }
                }
              }
            }
          }
        },
        "Header": {
          "properties": {
            "grid-area": "header",
            "display": "flex",
            "align-items": "center",
            "justify-content": "space-between",
            "padding": "0 32px",
            "background": "rgba(255,255,255,0.02)",
            "border-bottom": "1px solid rgba(255,255,255,0.05)"
          },
          "children": {
            "SearchBar": {
              "properties": {
                "display": "flex",
                "align-items": "center",
                "gap": "12px",
                "padding": "10px 16px",
                "background": "rgba(255,255,255,0.05)",
                "border-radius": "10px",
                "min-width": "320px"
              }
            },
            "UserMenu": {
              "properties": {
                "display": "flex",
                "align-items": "center",
                "gap": "16px"
              },
              "children": {
                "Avatar": {
                  "properties": {
                    "width": "40px",
                    "height": "40px",
                    "border-radius": "50%",
                    "background": "linear-gradient(135deg, #f093fb 0%, #f5576c 100%)"
                  }
                }
              }
            }
          }
        },
        "MainContent": {
          "properties": {
            "grid-area": "main",
            "padding": "32px",
            "overflow-y": "auto",
            "display": "grid",
            "grid-template-columns": "repeat(auto-fit, minmax(300px, 1fr))",
            "gap": "24px"
          },
          "children": {
            "StatsCard1": {
              "properties": {
                "background": "rgba(255,255,255,0.05)",
                "border-radius": "16px",
                "padding": "24px",
                "backdrop-filter": "blur(10px)",
                "border": "1px solid rgba(255,255,255,0.1)"
              }
            },
            "StatsCard2": {
              "properties": {
                "background": "rgba(255,255,255,0.05)",
                "border-radius": "16px",
                "padding": "24px",
                "backdrop-filter": "blur(10px)",
                "border": "1px solid rgba(255,255,255,0.1)"
              }
            }
          }
        }
      }
    },

    "MegaLayout_EcommercePDP": {
      "properties": {
        "display": "grid",
        "grid-template-columns": "1fr 1fr",
        "gap": "48px",
        "max-width": "1400px",
        "margin": "0 auto",
        "padding": "40px"
      },
      "children": {
        "ProductGallery": {
          "properties": {
            "display": "flex",
            "gap": "16px"
          },
          "children": {
            "Thumbnails": {
              "properties": {
                "display": "flex",
                "flex-direction": "column",
                "gap": "12px"
              },
              "children": {
                "Thumb1": {
                  "properties": {
                    "width": "80px",
                    "height": "80px",
                    "border-radius": "12px",
                    "border": "2px solid #667eea",
                    "cursor": "pointer"
                  }
                },
                "Thumb2": {
                  "properties": {
                    "width": "80px",
                    "height": "80px",
                    "border-radius": "12px",
                    "border": "2px solid transparent",
                    "cursor": "pointer",
                    "opacity": "0.6"
                  }
                }
              }
            },
            "MainImage": {
              "properties": {
                "flex": "1",
                "aspect-ratio": "1",
                "border-radius": "24px",
                "background": "linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)",
                "box-shadow": "0 25px 50px -12px rgba(0, 0, 0, 0.25)"
              }
            }
          }
        },
        "ProductInfo": {
          "properties": {
            "display": "flex",
            "flex-direction": "column",
            "gap": "24px"
          },
          "children": {
            "ProductTitle": {
              "properties": {
                "font-size": "36px",
                "font-weight": "700",
                "letter-spacing": "-1px",
                "color": "#1a1a2e"
              }
            },
            "ProductPrice": {
              "properties": {
                "font-size": "28px",
                "font-weight": "600",
                "color": "#667eea"
              }
            },
            "AddToCartBtn": {
              "properties": {
                "padding": "18px 36px",
                "background": "linear-gradient(135deg, #667eea 0%, #764ba2 100%)",
                "border-radius": "14px",
                "color": "white",
                "font-weight": "600",
                "font-size": "16px",
                "cursor": "pointer",
                "box-shadow": "0 10px 30px rgba(102, 126, 234, 0.4)",
                "transition": "transform 0.2s ease, box-shadow 0.2s ease"
              }
            }
          }
        }
      }
    },

    "ExtremeNesting_10Levels": {
      "properties": {
        "padding": "20px",
        "background": "#f0f0f0"
      },
      "children": {
        "Level1": {
          "properties": { "padding": "16px", "background": "hsl(0, 70%, 90%)", "border-radius": "12px" },
          "children": {
            "Level2": {
              "properties": { "padding": "16px", "background": "hsl(36, 70%, 90%)", "border-radius": "12px" },
              "children": {
                "Level3": {
                  "properties": { "padding": "16px", "background": "hsl(72, 70%, 90%)", "border-radius": "12px" },
                  "children": {
                    "Level4": {
                      "properties": { "padding": "16px", "background": "hsl(108, 70%, 90%)", "border-radius": "12px" },
                      "children": {
                        "Level5": {
                          "properties": { "padding": "16px", "background": "hsl(144, 70%, 90%)", "border-radius": "12px" },
                          "children": {
                            "Level6": {
                              "properties": { "padding": "16px", "background": "hsl(180, 70%, 90%)", "border-radius": "12px" },
                              "children": {
                                "Level7": {
                                  "properties": { "padding": "16px", "background": "hsl(216, 70%, 90%)", "border-radius": "12px" },
                                  "children": {
                                    "Level8": {
                                      "properties": { "padding": "16px", "background": "hsl(252, 70%, 90%)", "border-radius": "12px" },
                                      "children": {
                                        "Level9": {
                                          "properties": { "padding": "16px", "background": "hsl(288, 70%, 90%)", "border-radius": "12px" },
                                          "children": {
                                            "Level10": {
                                              "properties": { "padding": "16px", "background": "hsl(324, 70%, 90%)", "border-radius": "12px", "text-align": "center", "font-weight": "bold" }
                                            }
                                          }
                                        }
                                      }
                                    }
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },

